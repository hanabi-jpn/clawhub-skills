  "monitoring_settings": {
    "poll_interval_seconds": 30,
    "metrics_retention_hours": 168,
    "aggregation_intervals": ["1m", "5m", "15m", "1h", "6h", "24h"],
    "enable_real_time": true,
    "enable_historical": true,
    "enable_cost_tracking": true,
    "enable_performance_tracking": true,
    "enable_error_tracking": true,
    "log_level": "info"
  },
  "dashboard_settings": {
    "default_time_range": "24h",
    "available_time_ranges": ["1h", "6h", "24h", "7d", "30d"],
    "refresh_interval_seconds": 60,
    "theme": "dark",
    "chart_colors": {
      "primary": "#3B82F6",
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#8B5CF6",
      "neutral": "#6B7280",
      "series": ["#3B82F6", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#EC4899", "#14B8A6", "#F97316"]
    },
    "layout": {
      "sidebar_width": 240,
      "header_height": 64,
      "card_gap": 16,
      "border_radius": 12
    }
  },
  "notification_settings": {
    "channels": {
      "console": {
        "enabled": true,
        "min_severity": "warning"
      },
      "discord": {
        "enabled": false,
        "webhook_url": "",
        "min_severity": "critical",
        "mention_role": "@here"
      },
      "lark": {
        "enabled": false,
        "webhook_url": "",
        "min_severity": "warning"
      },
      "email": {
        "enabled": false,
        "smtp_config": {},
        "recipients": [],
        "min_severity": "critical"
      }
    },
    "cooldown_minutes": 15,
    "max_notifications_per_hour": 10,
    "escalation": {
      "enabled": true,
      "escalate_after_minutes": 30,
      "escalation_channel": "discord"
    }
  },
  "agent_profiles": {
