{
  "version": "1.0.0",
  "description": "Default configuration for Agent Dashboard monitoring, alerting, and cost tracking.",
  "alert_thresholds": {
    "error_rate": {
      "warning": 5,
      "critical": 15,
      "unit": "percent",
      "window_minutes": 60,
      "description": "Percentage of agent invocations returning errors within the window."
    },
    "response_time": {
      "warning": 30000,
      "critical": 120000,
      "unit": "milliseconds",
      "description": "Agent response time per invocation."
    },
    "token_usage_per_turn": {
      "warning": 50000,
      "critical": 100000,
      "unit": "tokens",
      "description": "Total tokens (input + output) consumed per agent turn."
    },
    "cost_per_hour": {
      "warning": 5.00,
      "critical": 15.00,
      "unit": "usd",
      "description": "Hourly cost rate across all active agents."
    },
    "cost_per_day": {
      "warning": 50.00,
      "critical": 150.00,
      "unit": "usd",
      "description": "Daily cost across all agents."
    },
    "cost_per_month": {
      "warning": 400.00,
      "critical": 1000.00,
      "unit": "usd",
      "description": "Monthly cost projection based on current burn rate."
    },
    "agent_idle_time": {
      "warning": 1800,
      "critical": 7200,
      "unit": "seconds",
      "description": "Time since last activity for an active agent."
    },
    "context_utilization": {
      "warning": 70,
      "critical": 90,
      "unit": "percent",
      "description": "Percentage of context window consumed."
    },
    "task_failure_streak": {
      "warning": 3,
      "critical": 5,
      "unit": "count",
      "description": "Consecutive failed tasks for a single agent."
    },
    "memory_usage": {
      "warning": 512,
      "critical": 1024,
      "unit": "megabytes",
      "description": "Process memory usage for agent runtime."
    }
  },
