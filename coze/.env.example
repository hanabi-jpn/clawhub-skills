# Coze API Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Personal Access Token (PAT)
# Get it from: https://www.coze.com/open/api
# Click "API Keys" or "Personal Access Token" -> Create
COZE_API_TOKEN=pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Workspace/Space ID
# Find it in the URL when viewing your workspace: coze.com/space/XXXXXXXXX
# Or run: python3 create_bots_api.py --validate-only  (lists all workspaces)
COZE_SPACE_ID=
