    "uniform_sentence_length": {
      "name": "均一な文長",
      "description": "AIは文の長さが均一になりがち。人間は短文と長文が自然に混在する",
      "weight": 0.75,
      "pattern_count": 12,
      "patterns": [
        "全ての文が20-30文字の範囲に収まっている",
